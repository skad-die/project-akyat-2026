<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground">

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <RelativeLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_back"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/summary_title"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:textColor="?android:attr/textColorPrimary"/>

        </RelativeLayout>

        <!-- PRIMARY STATS -->
        <LinearLayout
            android:id="@+id/llPrimaryStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/headerLayout"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/summary_duration"
                android:textSize="48sp"
                android:fontFamily="sans-serif-light"
                android:textColor="?android:attr/textColorPrimary"/>

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/summary_distance"
                android:textSize="26sp"
                android:fontFamily="sans-serif-light"
                android:textColor="?android:attr/textColorPrimary"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSteps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/summary_step_counter"
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorSecondary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:text="@string/dot"
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorSecondary"/>

                <TextView
                    android:id="@+id/tvCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/summary_calories"
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorSecondary"/>

            </LinearLayout>
        </LinearLayout>

        <!-- SPEED & PACE CARD -->
        <LinearLayout
            android:id="@+id/llSecondaryMetrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/llPrimaryStats"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_dashboard_section"
            android:padding="20dp"
            android:baselineAligned="false"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/avg_speed"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    tools:ignore="SmallSp"/>
                <TextView
                    android:id="@+id/tvSpeedAvg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/summary_speed_avg"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/max_speed"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    tools:ignore="SmallSp"/>
                <TextView
                    android:id="@+id/tvSpeedMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/summary_speed_max"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?android:attr/textColorPrimary"/>

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="?attr/colorOutlineVariant"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/avg_pace"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    tools:ignore="SmallSp"/>
                <TextView
                    android:id="@+id/tvPaceAvg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/summary_pace_avg"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/max_pace"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    tools:ignore="SmallSp"/>
                <TextView
                    android:id="@+id/tvPaceMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/summary_pace_max"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?android:attr/textColorPrimary"/>

            </LinearLayout>
        </LinearLayout>

        <!-- ELEVATION CARD -->
        <LinearLayout
            android:id="@+id/llElevation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/llSecondaryMetrics"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dashboard_section"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/elevation_label"
                android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary"
                tools:ignore="SmallSp"/>

            <TextView
                android:id="@+id/tvElevation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/summary_elevation"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?android:attr/textColorPrimary"/>

        </LinearLayout>

        <!-- BUTTONS -->
        <LinearLayout
            android:id="@+id/llButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/llElevation"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_save"
                android:textAllCaps="false"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/btnDiscard"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:text="@string/btn_discard"
                android:textAllCaps="false"
                android:textColor="@android:color/holo_red_dark"/>

        </LinearLayout>

    </RelativeLayout>
</ScrollView>